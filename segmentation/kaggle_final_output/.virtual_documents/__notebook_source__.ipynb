def resolve_dataset_root() -> Path:
    candidates = [
        DEFAULT_KAGGLE_DATASET_ROOT,
        Path('/kaggle/input/stanford-data/EchoNet-Dynamic'),
        Path('/kaggle/input/echonet-dynamic/EchoNet-Dynamic'),
        NOTEBOOK_DIR / 'segmentation' / 'data' / 'EchoNet-Dynamic',
